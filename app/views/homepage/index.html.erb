<%# Intro %>
<%= render ContainerComponent.new(class_name: "mt-9") do %>
  <div class="max-w-2xl">
    <h1 class="text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100">
      Señor Software Engineer
    </h1>
    <p class="mt-6 text-base text-zinc-600 dark:text-zinc-400">
      Hi, I&rsquo;m Václav, a programmer from the Czech Republic living in Seville. I&rsquo;ve been programming professionally for 16 years and enjoy both server and client-side work. I love learning new languages, frameworks, and tools. Outside of programming, I enjoy cycling, football, and chess.
    </p>
    <div class="mt-6 flex gap-6">
      <% social_links.each do |link| %>
        <%= link_to link[:href], "aria-label": link[:label], class: "group -m-1 p-1" do %>
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 fill-zinc-500 transition group-hover:fill-zinc-600 dark:fill-zinc-400 dark:group-hover:fill-zinc-300"><%= link[:icon] %></svg>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<%# Photos %>
<div class="mt-16 sm:mt-20">
  <div class="-my-4 flex justify-center gap-5 overflow-hidden py-4 sm:gap-8">
    <% photos = [
         ["vaclav-bea-japan.jpg", "Václav and Bea in Japan"],
         ["vaclav-cycling.jpg", "Václav out on a bike ride"],
         ["vaclav-ramen.jpg", "Václav with a bowl of ramen"],
         ["freddie.jpg", "Freddie"],
         ["vaclav-cycling-selfie.jpg", "Václav taking a cycling selfie"],
       ] %>
    <% photos.each_with_index do |(image, caption), i| %>
      <% rotation = ["rotate-2", "-rotate-2", "rotate-2", "rotate-2", "-rotate-2"][i % 5] %>
      <div class="relative w-44 flex-none overflow-hidden rounded-xl bg-zinc-100 sm:w-72 sm:rounded-2xl dark:bg-zinc-800 <%= rotation %>">
        <div class="aspect-9/10">
          <%= image_tag image, alt: caption, sizes: "(min-width: 640px) 18rem, 11rem", class: "absolute inset-0 h-full w-full object-cover" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# Articles + sidebar %>
<%= render ContainerComponent.new(class_name: "mt-24 md:mt-28") do %>
  <div class="mx-auto grid max-w-xl grid-cols-1 gap-y-20 lg:max-w-none lg:grid-cols-2">
    <%# Latest articles %>
    <div class="flex flex-col gap-16">
      <% @posts.each do |post| %>
        <%= render CardComponent.new(as: :article) do |card| %>
          <% card.with_title(href: post_path(post)) { post.title } %>
          <% card.with_eyebrow(as: :time, decorate: true, datetime: post.published_at.iso8601) { post.published_at.strftime("%B %-d, %Y") } %>
          <% card.with_description { post.perex } %>
          <% card.with_cta { "Read article" } %>
        <% end %>
      <% end %>
    </div>

    <%# Resume %>
    <div class="space-y-10 lg:pl-16 xl:pl-24">
      <div class="rounded-2xl border border-zinc-100 p-6 dark:border-zinc-700/40">
        <h2 class="flex text-sm font-semibold text-zinc-900 dark:text-zinc-100">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="h-6 w-6 flex-none">
            <path d="M2.75 9.75a3 3 0 0 1 3-3h12.5a3 3 0 0 1 3 3v8.5a3 3 0 0 1-3 3H5.75a3 3 0 0 1-3-3v-8.5Z" class="fill-zinc-100 stroke-zinc-400 dark:fill-zinc-100/10 dark:stroke-zinc-500" />
            <path d="M3 14.25h6.249c.484 0 .952-.002 1.316.319l.777.682a.996.996 0 0 0 1.316 0l.777-.682c.364-.32.832-.319 1.316-.319H21M8.75 6.5V4.75a2 2 0 0 1 2-2h2.5a2 2 0 0 1 2 2V6.5" class="stroke-zinc-400 dark:stroke-zinc-500" />
          </svg>
          <span class="ml-3">Work</span>
        </h2>
        <ol class="mt-6 space-y-4">
          <% @work_experiences.each do |role| %>
            <% start_year = role.started_on.year %>
            <% end_year = role.ongoing? ? "Present" : role.ended_on.year %>
            <li class="flex gap-4">
              <div class="relative mt-1 flex h-10 w-10 flex-none items-center justify-center rounded-full shadow-md ring-1 shadow-zinc-800/5 ring-zinc-900/5 dark:border dark:border-zinc-700/50 dark:bg-zinc-800 dark:ring-0">
                <%= image_tag role.logo, alt: "", class: "h-7 w-7" %>
              </div>
              <dl class="flex flex-auto flex-wrap gap-x-2">
                <dt class="sr-only">Company</dt>
                <dd class="w-full flex-none text-sm font-medium text-zinc-900 dark:text-zinc-100"><%= role.company %></dd>
                <dt class="sr-only">Role</dt>
                <dd class="text-xs text-zinc-500 dark:text-zinc-400"><%= role.role %></dd>
                <dt class="sr-only">Date</dt>
                <dd class="ml-auto text-xs text-zinc-400 dark:text-zinc-500" aria-label="<%= start_year %> until <%= end_year %>">
                  <time datetime="<%= start_year %>"><%= start_year %></time>
                  <span aria-hidden="true">—</span>
                  <time datetime="<%= role.ongoing? ? Date.current.year : end_year %>"><%= end_year %></time>
                </dd>
              </dl>
            </li>
          <% end %>
        </ol>
        <%= render ButtonComponent.new(href: "#", variant: :secondary, class_name: "group mt-6 w-full") do %>
          Download CV
          <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" class="h-4 w-4 stroke-zinc-400 transition group-active:stroke-zinc-600 dark:group-hover:stroke-zinc-50 dark:group-active:stroke-zinc-50">
            <path d="M4.75 8.75 8 12.25m0 0 3.25-3.5M8 12.25v-8.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
