<% content_for :title, "Projects" %>

<div class="mb-8 flex items-center justify-between gap-4">
  <h1 class="text-2xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100">Projects</h1>
  <%= link_to "New project", new_admin_project_path, class: "inline-flex items-center justify-center rounded-md bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-500 dark:bg-teal-500 dark:hover:bg-teal-400" %>
</div>

<% if @projects.any? %>
  <div class="overflow-hidden rounded-xl bg-white ring-1 ring-zinc-200 dark:bg-zinc-900 dark:ring-zinc-800">
    <table class="min-w-full divide-y divide-zinc-200 dark:divide-zinc-800">
      <thead class="bg-zinc-50 dark:bg-zinc-800/50">
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Name</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Description</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Link</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Logo</th>
          <th scope="col" class="relative px-4 py-3"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-100 dark:divide-zinc-800">
        <% @projects.each do |project| %>
          <tr class="transition hover:bg-zinc-50 dark:hover:bg-zinc-800/40">
            <td class="px-4 py-3 text-sm font-medium text-zinc-800 dark:text-zinc-100"><%= link_to project.name, [ :admin, project ], class: "font-medium text-teal-600 hover:text-teal-500 dark:text-teal-400" %></td>
            <td class="px-4 py-3 text-sm text-zinc-600 dark:text-zinc-400"><%= project.description %></td>
            <td class="px-4 py-3 text-sm text-zinc-600 dark:text-zinc-400"><%= project.link %></td>
            <td class="px-4 py-3 text-sm font-mono text-zinc-600 dark:text-zinc-400"><%= project.logo %></td>
            <td class="px-4 py-3 text-right text-sm">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Edit", edit_admin_project_path(project), class: "font-medium text-teal-600 hover:text-teal-500 dark:text-teal-400" %>
                <%= button_to "Delete", admin_project_path(project), method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "font-medium text-red-600 hover:text-red-500 dark:text-red-400" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-400">No projects yet.</div>
<% end %>
