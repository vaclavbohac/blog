<% content_for :title, @series.title %>

<div class="mb-8 flex items-center justify-between gap-4">
  <h1 class="text-2xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100"><%= @series.title %></h1>
  <div class="flex items-center gap-3">
    <%= link_to "Edit", edit_admin_series_path(@series), class: "inline-flex items-center justify-center rounded-md bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-500 dark:bg-teal-500 dark:hover:bg-teal-400" %>
    <%= link_to "Back", admin_series_index_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm transition hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-200 dark:hover:bg-zinc-700" %>
  </div>
</div>

<div class="space-y-6">
  <div class="overflow-hidden rounded-xl bg-white px-6 py-5 ring-1 ring-zinc-200 dark:bg-zinc-900 dark:ring-zinc-800">
    <dl class="space-y-4">
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Perex</dt>
        <dd class="mt-1 text-sm text-zinc-700 dark:text-zinc-300"><%= @series.perex.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Position</dt>
        <dd class="mt-1 text-sm text-zinc-700 dark:text-zinc-300"><%= @series.position %></dd>
      </div>
    </dl>
  </div>

  <div>
    <h2 class="mb-3 text-lg font-semibold tracking-tight text-zinc-800 dark:text-zinc-100">Posts</h2>
    <% if @series.posts.any? %>
      <div class="overflow-hidden rounded-xl bg-white ring-1 ring-zinc-200 dark:bg-zinc-900 dark:ring-zinc-800">
        <ul class="divide-y divide-zinc-100 dark:divide-zinc-800">
          <% @series.posts.each do |post| %>
            <li class="px-4 py-3 text-sm transition hover:bg-zinc-50 dark:hover:bg-zinc-800/40">
              <%= link_to post.title, admin_post_path(post), class: "font-medium text-teal-600 hover:text-teal-500 dark:text-teal-400" %>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <div class="rounded-xl border border-dashed border-zinc-300 bg-white px-6 py-12 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-400">No posts in this series yet.</div>
    <% end %>
  </div>
</div>
