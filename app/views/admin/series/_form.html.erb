<%= form_with model: [ :admin, @series ] do |f| %>
  <% if @series.errors.any? %>
    <div class="mb-6 rounded-md bg-red-50 px-4 py-3 text-sm text-red-700 ring-1 ring-red-600/20 dark:bg-red-400/10 dark:text-red-300 dark:ring-red-400/20">
      <%= pluralize(@series.errors.count, "error") %> prevented saving.
      <ul class="mt-1 list-disc list-inside"><% @series.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <div class="space-y-6">
    <div class="space-y-2">
      <%= f.label :title, class: "block text-sm font-medium text-zinc-700 dark:text-zinc-300" %>
      <%= f.text_field :title, class: "block w-full rounded-md border #{f.object.errors[:title].any? ? 'border-red-400 focus:outline-red-500 dark:border-red-500' : 'border-zinc-300 focus:border-teal-500 focus:outline-teal-500 dark:border-zinc-700'} bg-white px-3 py-2 text-sm text-zinc-900 shadow-sm transition placeholder:text-zinc-400 focus:outline-2 dark:bg-zinc-800 dark:text-zinc-100" %>
      <% f.object.errors[:title].each do |msg| %>
        <p class="mt-1 text-sm text-red-600 dark:text-red-400"><%= msg %></p>
      <% end %>
    </div>

    <div class="space-y-2">
      <%= f.label :perex, class: "block text-sm font-medium text-zinc-700 dark:text-zinc-300" %>
      <%= f.text_area :perex, rows: 4, class: "block w-full rounded-md border #{f.object.errors[:perex].any? ? 'border-red-400 focus:outline-red-500 dark:border-red-500' : 'border-zinc-300 focus:border-teal-500 focus:outline-teal-500 dark:border-zinc-700'} bg-white px-3 py-2 text-sm text-zinc-900 shadow-sm transition placeholder:text-zinc-400 focus:outline-2 dark:bg-zinc-800 dark:text-zinc-100" %>
      <% f.object.errors[:perex].each do |msg| %>
        <p class="mt-1 text-sm text-red-600 dark:text-red-400"><%= msg %></p>
      <% end %>
    </div>

    <div class="space-y-2">
      <%= f.label :position, class: "block text-sm font-medium text-zinc-700 dark:text-zinc-300" %>
      <%= f.number_field :position, class: "block w-full rounded-md border #{f.object.errors[:position].any? ? 'border-red-400 focus:outline-red-500 dark:border-red-500' : 'border-zinc-300 focus:border-teal-500 focus:outline-teal-500 dark:border-zinc-700'} bg-white px-3 py-2 text-sm text-zinc-900 shadow-sm transition placeholder:text-zinc-400 focus:outline-2 dark:bg-zinc-800 dark:text-zinc-100" %>
      <% f.object.errors[:position].each do |msg| %>
        <p class="mt-1 text-sm text-red-600 dark:text-red-400"><%= msg %></p>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-6">
    <%= f.submit class: "inline-flex items-center justify-center rounded-md bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-500 disabled:opacity-50 dark:bg-teal-500 dark:hover:bg-teal-400" %>
    <%= link_to "Cancel", admin_series_index_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 shadow-sm transition hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-200 dark:hover:bg-zinc-700" %>
  </div>
<% end %>
