<%= form_with(model: work_experience, class: "contents") do |form| %>
  <% if work_experience.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(work_experience.errors.count, "error") %> prohibited this work_experience from being saved:</h2>

      <ul class="list-disc ml-6">
        <% work_experience.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :company %>
    <%= form.text_field :company, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": work_experience.errors[:company].none?, "border-red-400 focus:outline-red-600": work_experience.errors[:company].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :role %>
    <%= form.text_field :role, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": work_experience.errors[:role].none?, "border-red-400 focus:outline-red-600": work_experience.errors[:role].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :logo %>
    <%= form.text_field :logo, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": work_experience.errors[:logo].none?, "border-red-400 focus:outline-red-600": work_experience.errors[:logo].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :started_on %>
    <%= form.date_field :started_on, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": work_experience.errors[:started_on].none?, "border-red-400 focus:outline-red-600": work_experience.errors[:started_on].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :ended_on %>
    <%= form.date_field :ended_on, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": work_experience.errors[:ended_on].none?, "border-red-400 focus:outline-red-600": work_experience.errors[:ended_on].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
