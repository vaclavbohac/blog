<!DOCTYPE html>
<html lang="en" class="h-full antialiased">
  <head>
    <% site_title = "Václav Boháč | Señor Software Engineer" %>
    <title><%= content_for?(:title) ? "#{content_for(:title)} · #{site_title}" : site_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Blog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Apply the saved (or system) theme before first paint to avoid a flash of the wrong theme. %>
    <script>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var dark = stored
            ? stored === "dark"
            : window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
        } catch (e) {}
      })();
    </script>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "syntax", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex h-full bg-zinc-50 dark:bg-black">
    <div class="flex w-full">
      <%# Fixed page-width "card" background behind all content. %>
      <div class="fixed inset-0 flex justify-center sm:px-8">
        <div class="flex w-full max-w-7xl lg:px-8">
          <div class="w-full bg-white ring-1 ring-zinc-100 dark:bg-zinc-900 dark:ring-zinc-300/20"></div>
        </div>
      </div>

      <div class="relative flex w-full flex-col">
        <%# Admin navigation %>
        <% admin_links = [
             ["Dashboard", admin_root_path],
             ["Posts",     admin_posts_path],
             ["Series",    admin_series_index_path],
             ["Projects",  admin_projects_path],
             ["Work",      admin_work_experiences_path],
           ] %>
        <header class="relative z-50 flex flex-none flex-col">
          <div class="sticky top-0 z-10 pt-6">
            <%= render ContainerComponent.new do %>
              <nav class="flex items-center gap-4 rounded-full bg-white/90 px-4 py-2 text-sm font-medium text-zinc-800 shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 backdrop-blur-sm dark:bg-zinc-800/90 dark:text-zinc-200 dark:ring-white/10">
                <ul class="flex flex-1 flex-wrap items-center gap-1">
                  <% admin_links.each do |name, path| %>
                    <% active = admin_nav_active?(path) %>
                    <li>
                      <%= link_to name, path, class: "relative block rounded-full px-3 py-1.5 transition #{active ? 'bg-teal-50 text-teal-600 dark:bg-teal-400/10 dark:text-teal-400' : 'hover:text-teal-500 dark:hover:text-teal-400'}" %>
                    </li>
                  <% end %>
                </ul>

                <div class="flex items-center gap-2">
                  <%= link_to "View site", root_path, class: "rounded-full px-3 py-1.5 text-zinc-600 transition hover:text-teal-500 dark:text-zinc-400 dark:hover:text-teal-400" %>
                  <%= button_to "Sign out", session_path, method: :delete, class: "rounded-full bg-zinc-100 px-3 py-1.5 font-medium text-zinc-700 transition hover:bg-zinc-200 dark:bg-zinc-700 dark:text-zinc-200 dark:hover:bg-zinc-600" %>
                </div>
              </nav>
            <% end %>
          </div>
        </header>

        <main class="flex-auto py-12">
          <%= render ContainerComponent.new do %>
            <% if flash[:notice] %>
              <div class="mb-6 rounded-xl bg-teal-50 px-4 py-3 text-sm font-medium text-teal-700 ring-1 ring-teal-600/20 dark:bg-teal-400/10 dark:text-teal-300 dark:ring-teal-400/20">
                <%= flash[:notice] %>
              </div>
            <% end %>
            <% if flash[:alert] %>
              <div class="mb-6 rounded-xl bg-red-50 px-4 py-3 text-sm font-medium text-red-700 ring-1 ring-red-600/20 dark:bg-red-400/10 dark:text-red-300 dark:ring-red-400/20">
                <%= flash[:alert] %>
              </div>
            <% end %>

            <%= yield %>
          <% end %>
        </main>
      </div>
    </div>
  </body>
</html>
